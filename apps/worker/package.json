{
  "name": "@play/worker",
  "version": "0.0.0",
  "private": true,
  "description": "BullMQ-Consumer: FFmpeg-HLS-Transcode + yt-dlp-Imports (v0.2).",
  "type": "module",
  "exports": {
    "./queue": {
      "types": "./src/queue.ts",
      "default": "./src/queue.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "echo 'no build step — runs tsx directly'",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@play/db": "workspace:*",
    "@play/shared": "workspace:*",
    "@play/storage": "workspace:*",
    "bullmq": "^5.34.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.4.2",
    "youtube-dl-exec": "^3.0.22"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

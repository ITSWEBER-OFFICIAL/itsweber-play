{
  "name": "@play/api",
  "version": "0.0.0",
  "private": true,
  "description": "Fastify + Better Auth + tRPC. Hostet /api/auth/* und /trpc/* für apps/web.",
  "type": "module",
  "exports": {
    "./trpc": {
      "types": "./src/trpc/routers/index.ts",
      "default": "./src/trpc/routers/index.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "echo 'no build step — runs tsx directly'",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.2",
    "@play/db": "workspace:*",
    "@play/shared": "workspace:*",
    "@play/storage": "workspace:*",
    "@play/theme": "workspace:*",
    "@play/worker": "workspace:*",
    "@trpc/server": "^11.17.0",
    "better-auth": "^1.6.10",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.7",
    "file-type": "^21.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

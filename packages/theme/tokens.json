{
  "$schema": "./tokens.schema.json",
  "description": "ITSWEBER Play — Primitive Design Tokens (Ebene 1). Semantic Layer in semantic.ts leitet daraus ab.",
  "color": {
    "neutral": {
      "50":  "#f6f8fa",
      "100": "#e6edf3",
      "200": "#c9d1d9",
      "300": "#8b949e",
      "400": "#6e7681",
      "500": "#484f58",
      "600": "#30363d",
      "700": "#21262d",
      "800": "#161b22",
      "900": "#0e1116"
    },
    "teal": {
      "50":  "#e6f7f7",
      "100": "#bfebea",
      "200": "#8fd9d8",
      "300": "#5fc7c6",
      "400": "#3ba7a7",
      "500": "#3ba7a7",
      "600": "#2d8a8a",
      "700": "#236e6e",
      "800": "#1a5252",
      "900": "#113636"
    },
    "red":    { "500": "#d9534f", "600": "#b43935" },
    "amber":  { "500": "#f0b429", "600": "#cb8e14" },
    "green":  { "500": "#3fb950", "600": "#2ea043" }
  },
  "font": {
    "sans":    "'Geist', 'Geist Variable', system-ui, -apple-system, 'Segoe UI', sans-serif",
    "mono":    "'Geist Mono', 'Geist Mono Variable', ui-monospace, 'SF Mono', monospace",
    "display": "'Geist', 'Geist Variable', sans-serif"
  },
  "fontSize": {
    "xs":   "0.75rem",
    "sm":   "0.875rem",
    "base": "1rem",
    "lg":   "1.125rem",
    "xl":   "1.25rem",
    "2xl":  "1.5rem",
    "3xl":  "1.875rem",
    "4xl":  "2.25rem",
    "5xl":  "3rem"
  },
  "radius": {
    "none": "0",
    "sm":   "6px",
    "md":   "10px",
    "lg":   "16px",
    "xl":   "24px",
    "full": "9999px"
  },
  "spacing": {
    "0":  "0",
    "1":  "0.25rem",
    "2":  "0.5rem",
    "3":  "0.75rem",
    "4":  "1rem",
    "5":  "1.25rem",
    "6":  "1.5rem",
    "8":  "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem"
  },
  "shadow": {
    "sm":   "0 1px 2px rgba(0,0,0,.25)",
    "md":   "0 2px 8px rgba(0,0,0,.30)",
    "card": "0 4px 20px rgba(0,0,0,.35)",
    "lg":   "0 12px 40px rgba(0,0,0,.45)",
    "glow": "0 0 12px var(--color-teal-500)"
  },
  "logoFilter": {
    "none":       "none",
    "glow":       "drop-shadow(0 0 12px var(--color-teal-500))",
    "softGlow":   "drop-shadow(0 0 6px rgba(59,167,167,.6))",
    "duotone":    "grayscale(1) brightness(1.1) sepia(.3) hue-rotate(140deg) saturate(3)",
    "shadow":     "drop-shadow(0 4px 8px rgba(0,0,0,.5))",
    "brightness0":"brightness(0)",
    "invert":     "invert(1)",
    "invertGlow": "invert(1) drop-shadow(0 0 12px var(--color-teal-500))",
    "mono":       "grayscale(1) contrast(1.2) brightness(1.05)",
    "onlyWhite":  "brightness(0) invert(1)"
  },
  "transition": {
    "fast":   "120ms cubic-bezier(.4,0,.2,1)",
    "base":   "200ms cubic-bezier(.4,0,.2,1)",
    "slow":   "350ms cubic-bezier(.4,0,.2,1)"
  }
}

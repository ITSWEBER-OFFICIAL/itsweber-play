# ─────────────────────────────────────────────────────────────
#  Play — .env.production.example
#  Kopie nach `.env` AUF DEM HOST (nicht commiten!).
#
#  MUSS gesetzt sein vor erstem `docker compose up -d`:
#    POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD      ← `openssl rand -hex 24`
#    MINIO_ROOT_USER, MINIO_ROOT_PASSWORD               ← `openssl rand -hex 24`
#    AUTH_SECRET                                        ← `openssl rand -hex 32`
#    NEXT_PUBLIC_API_URL, NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_S3_PUBLIC_URL
#    INITIAL_ADMIN_*                                    ← erster Login
#
#  ACHTUNG: `NEXT_PUBLIC_*` wird zur Build-Zeit ins JS-Bundle gebacken. Nach
#  Ändern MUSS play-web neu gebaut werden (`docker compose build play-web`).
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
APP_NAME="Play"

# ── User-Branding (Frontend, optional) ──────────────────────
# Fork-freundlich: alle Werte leer lassen für „generisch" — der
# Upstream-Attribution-Footer (AGPL-3.0) erscheint in jedem Fall.
NEXT_PUBLIC_APP_NAME="Play"
NEXT_PUBLIC_PRODUCT_HOMEPAGE=
NEXT_PUBLIC_VENDOR_NAME=
NEXT_PUBLIC_VENDOR_URL=
NEXT_PUBLIC_AUTHOR_NAME=
NEXT_PUBLIC_AUTHOR_URL=

# ── Public URLs (Prod: eigene DNS-Namen + HTTPS via Reverse-Proxy) ──
# PUBLIC_URL: externer Root der Plattform (Web-Frontend). CORS-allowed Origin.
PUBLIC_URL=https://play.example.com
# API_URL: Server-zu-Server (nur Web-Container → API-Container, intern).
API_URL=http://play-api:4000
# Browser-sichtbare URLs — werden in JS-Bundle gebakt.
NEXT_PUBLIC_API_URL=https://api.play.example.com
NEXT_PUBLIC_SITE_URL=https://play.example.com
NEXT_PUBLIC_S3_PUBLIC_URL=https://minio.play.example.com
# Server-seitige Asset-URL-Basis — MUSS identisch zu NEXT_PUBLIC_S3_PUBLIC_URL sein.
S3_PUBLIC_URL=https://minio.play.example.com

# ── Initial-Admin ────────────────────────────────────────────
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_HANDLE=admin
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_PASSWORD=change-me-strong-password

# ── Auth ─────────────────────────────────────────────────────
# ERZEUGEN: `openssl rand -hex 32`
AUTH_SECRET=replace-with-64-char-random-hex
# Cookie-Domain: Punkt-Prefix erlaubt Subdomain-Sharing (api.play.example.com ↔ play.example.com).
AUTH_COOKIE_DOMAIN=.example.com

# Optional: OIDC (z. B. Authentik, Keycloak). Leer lassen für internes Auth.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=play-postgres
POSTGRES_PORT=5432
POSTGRES_DB=itsweber_play
POSTGRES_USER=play
# ERZEUGEN: `openssl rand -hex 24`
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql://play:change-me-strong@play-postgres:5432/itsweber_play

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=play-redis
REDIS_PORT=6379

# ── MinIO ────────────────────────────────────────────────────
# ERZEUGEN: beide per `openssl rand -hex 24`
MINIO_ROOT_USER=play-admin
MINIO_ROOT_PASSWORD=change-me-strong-too
S3_ENDPOINT=http://play-minio:9000
S3_REGION=us-east-1
S3_BUCKET_VIDEOS=play-videos
S3_BUCKET_THUMBS=play-thumbs
S3_BUCKET_RAW=play-raw
S3_BUCKET_ASSETS=play-assets
S3_ACCESS_KEY=play-admin
S3_SECRET_KEY=change-me-strong-too

# ── Video-Pipeline ───────────────────────────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
YT_DLP_PATH=/usr/local/bin/yt-dlp
# max. Upload-Größe — spiegelt Reverse-Proxy `client_max_body_size`. 8 GB = 8192.
MAX_UPLOAD_SIZE_MB=8192
TRANSCODE_QUALITIES=1080p,720p,480p
TRANSCODE_CONCURRENCY=2
IMPORT_CONCURRENCY=2
# Worker-Zusatz-Codecs (AV1/VP9). Default leer. CPU-Kosten beachten.
# Beispiel: TRANSCODE_EXTRA_CODECS=av1,vp9
TRANSCODE_EXTRA_CODECS=

# ── Rate-Limit ───────────────────────────────────────────────
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# ── Telemetry (optional) ─────────────────────────────────────
SENTRY_DSN=

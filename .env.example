# ─────────────────────────────────────────────────────────────
#  ITSWEBER Play — .env.example (DEV / lokal)
#  Kopie für `.env` zum Starten via `docker compose -f docker-compose.dev.yml up`.
#  Für Produktion → siehe .env.production.example.
#
#  MUSS gesetzt sein vor erstem Start (Compose prüft):
#    POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD,
#    MINIO_ROOT_USER, MINIO_ROOT_PASSWORD,
#    NEXT_PUBLIC_API_URL, NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_S3_PUBLIC_URL,
#    AUTH_SECRET
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="Play (Dev)"

# ── User-Branding (Frontend, optional) ──────────────────────
# Diese Werte steuern das sichtbare Branding im UI (Header, Footer, Metadata).
# Alle NEXT_PUBLIC_*-Werte landen im JS-Bundle und sind Browser-sichtbar.
# Leer lassen für „generisch" — der Upstream-Attribution-Footer
# (AGPL-3.0) bleibt in jedem Fall angezeigt.
NEXT_PUBLIC_APP_NAME="Play"
NEXT_PUBLIC_PRODUCT_HOMEPAGE=
NEXT_PUBLIC_VENDOR_NAME=
NEXT_PUBLIC_VENDOR_URL=
NEXT_PUBLIC_AUTHOR_NAME=
NEXT_PUBLIC_AUTHOR_URL=

# ── Public URLs (lokal: alles über localhost) ───────────────
# PUBLIC_URL: extern sichtbare Root-URL (CORS + Auth-Callbacks).
PUBLIC_URL=http://localhost:3000
# API_URL: SSR-seitig genutzter API-Endpunkt (Server-zu-Server, kein DNS nötig).
API_URL=http://play-api:4000
# NEXT_PUBLIC_*: ins JS-Bundle kompiliert, Browser-sichtbar.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_S3_PUBLIC_URL=http://localhost:9000
# S3_PUBLIC_URL: Server-seitige Asset-URL-Basis (gleicher Wert wie oben, ohne CDN).
S3_PUBLIC_URL=http://localhost:9000

# ── Initial-Admin (wird beim ersten Boot angelegt, wenn DB leer) ─
INITIAL_ADMIN_EMAIL=admin@itsweber.local
INITIAL_ADMIN_HANDLE=admin
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_PASSWORD=change-me-strong-password

# ── Auth ─────────────────────────────────────────────────────
# 64-char hex: `openssl rand -hex 32` — für Dev reicht ein konstanter Wert.
AUTH_SECRET=dev-only-auth-secret-change-me-64-char-hex
# Dev: Cookie ohne Domain-Pin (läuft auf localhost).
AUTH_COOKIE_DOMAIN=

# Optional: Authentik OIDC — leer lassen für MVP.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=play-postgres
POSTGRES_PORT=5432
POSTGRES_DB=itsweber_play
POSTGRES_USER=play
POSTGRES_PASSWORD=play-dev-password
DATABASE_URL=postgresql://play:play-dev-password@play-postgres:5432/itsweber_play

# ── Redis (BullMQ + Cache + Rate-Limit) ──────────────────────
REDIS_HOST=play-redis
REDIS_PORT=6379

# ── MinIO (S3-kompatibel) ────────────────────────────────────
MINIO_ROOT_USER=play-admin
MINIO_ROOT_PASSWORD=play-dev-password
S3_ENDPOINT=http://play-minio:9000
S3_REGION=us-east-1
S3_BUCKET_VIDEOS=play-videos
S3_BUCKET_THUMBS=play-thumbs
S3_BUCKET_RAW=play-raw
S3_BUCKET_ASSETS=play-assets
S3_ACCESS_KEY=play-admin
S3_SECRET_KEY=play-dev-password

# ── Video-Pipeline ───────────────────────────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
YT_DLP_PATH=/usr/local/bin/yt-dlp
MAX_UPLOAD_SIZE_MB=8192
TRANSCODE_QUALITIES=1080p,720p,480p
TRANSCODE_CONCURRENCY=2
IMPORT_CONCURRENCY=2
# Worker-Zusatz-Codecs hinter Flag (AV1/VP9). Kommaliste, Default leer.
# Werte: "av1", "vp9". Kostet viel CPU — nur anschalten, wenn du weißt warum.
TRANSCODE_EXTRA_CODECS=

# ── Rate-Limit (Fastify, Redis-backed) ───────────────────────
# Requests pro Fenster (ms) auf sensible Endpoints (auth/search/comment/report).
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# ── Telemetry (optional) ─────────────────────────────────────
SENTRY_DSN=
